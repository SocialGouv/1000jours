  type: ClusterIP
---
apiVersion: extensions/v1beta1
kind: Ingress
metadata:
  annotations:
    kubernetes.io/ingress.class: nginx
    kapp.k14s.io/disable-default-ownership-label-rules: ''
    kapp.k14s.io/disable-default-label-scoping-rules: ''
    app.gitlab.com/app: ddd
    app.gitlab.com/env: dddd
    app.gitlab.com/env.name: ddd
  labels:
    app: strapi
    application: v1-2-3-xxx
    owner: xxx
    team: xxx
  name: strapi
  namespace: dddd
spec:
  rules:
    - host: strapi-v1-2-3-xxx.ddd
      http:
        paths:
          - backend:
              serviceName: strapi
              servicePort: 80
            path: /
  tls:
    - hosts:
        - strapi-v1-2-3-xxx.ddd
      secretName: wildcard-crt
"
`;
